# =============================================================
# dag-curator — Environment Variables
# =============================================================
# Copy this file to .env.local for local development

# -----------------------------------------------
# Database
# -----------------------------------------------
# Local development (SQLite file)
DATABASE_URL=file:./local.db

# Production (Turso — distributed libSQL)
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# -----------------------------------------------
# Authentication (NextAuth.js v5 / Auth.js)
# -----------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here  # openssl rand -base64 32

# GitHub OAuth App (create at github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Access control: comma-separated GitHub org names whose members can log in
# Leave empty to allow any GitHub user
ALLOWED_GITHUB_ORGS=dagpedia

# -----------------------------------------------
# GitHub API (for PR creation)
# -----------------------------------------------
# Personal Access Token or GitHub App token with:
#   - repo:write on dagpedia/dagpedia
GITHUB_TOKEN=ghp_your-token-here

# -----------------------------------------------
# Anthropic API (Claude — LLM extraction)
# -----------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# -----------------------------------------------
# dagpedia target repository
# -----------------------------------------------
DAGPEDIA_REPO=dagpedia/dagpedia
DAGPEDIA_BASE_BRANCH=main

# -----------------------------------------------
# Vercel Cron Security
# -----------------------------------------------
# Set a random secret; include as Bearer token in Vercel cron requests
CRON_SECRET=your-cron-secret

# -----------------------------------------------
# PubMed (NCBI E-utils)
# -----------------------------------------------
# Optional: NCBI API key for higher rate limits (10 req/s vs 3 req/s)
# NCBI_API_KEY=your-ncbi-api-key

# -----------------------------------------------
# Unpaywall (open-access full-text)
# -----------------------------------------------
# Your email address (required by Unpaywall API)
UNPAYWALL_EMAIL=your@email.com
