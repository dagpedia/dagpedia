{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dagpedia.org/schema/vocabulary-file.json",
  "title": "DAGpedia vocabulary file",
  "type": "object",
  "required": ["vocabularies"],
  "additionalProperties": false,
  "properties": {
    "vocabularies": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/vocabulary" }
    }
  },
  "$defs": {
    "vocabulary": {
      "type": "object",
      "required": ["open", "entries"],
      "additionalProperties": false,
      "properties": {
        "open": { "type": "boolean" },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/entry" }
        }
      }
    },
    "entry": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "label": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    }
  }
}
