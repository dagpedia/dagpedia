{
  "name": "dagpedia",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run generate-index && next dev",
    "prebuild": "node --input-type=module -e \"import('fumadocs-mdx/next').then(m => m.postInstall())\" && tsx scripts/generate-search-index.ts && tsx scripts/generate-dag-data.ts",
    "build": "next build",
    "generate-index": "tsx scripts/generate-search-index.ts && tsx scripts/generate-dag-data.ts",
    "generate-dag-data": "tsx scripts/generate-dag-data.ts",
    "generate-dag-meta": "tsx scripts/generate-dag-meta.ts",
    "verify-dag-layout": "tsx scripts/verify-dag-layout.ts",
    "start": "next start",
    "lint": "next lint",
    "validate": "python scripts/nodes/validate_nodes.py --all && python scripts/dag/validate_dag.py --all && python scripts/docs/validate_adr.py --all && tsx scripts/generate-dag-data.ts --check"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dagrejs/dagre": "^3.0.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fumadocs-core": "^15.8.5",
    "fumadocs-mdx": "^11.10.1",
    "fumadocs-ui": "^15.8.5",
    "gray-matter": "^4.0.3",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.16.0",
    "next": "^15.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.11.1",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.2",
    "typescript": "^5.6.0"
  }
}
